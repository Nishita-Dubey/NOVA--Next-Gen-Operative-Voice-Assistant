import subprocess
import psutil
import os
from utils.logger import get_logger

logger = get_logger("app_manager")

APP_MAP = {
    "chrome":       "chrome.exe",
    "google chrome":"chrome.exe",
    "firefox":      "firefox.exe",
    "notepad":      "notepad.exe",
    "calculator":   "calc.exe",
    "paint":        "mspaint.exe",
    "word":         "WINWORD.EXE",
    "excel":        "EXCEL.EXE",
    "powerpoint":   "POWERPNT.EXE",
    "vlc":          "vlc.exe",
    "spotify":      "spotify.exe",
    "vscode":       "code.exe",
    "vs code":      "code.exe",
    "cmd":          "cmd.exe",
    "terminal":     "cmd.exe",
    "file explorer":"explorer.exe",
    "explorer":     "explorer.exe",
    "task manager": "taskmgr.exe",
    "edge":         "msedge.exe",
    "whatsapp":     "WhatsApp.exe",
    "telegram":     "Telegram.exe",
    "discord":      "Discord.exe",
}

class ApplicationManager:
    def open_app(self, app_name: str) -> dict:
        key = app_name.lower().strip()
        exe = APP_MAP.get(key, key)
        try:
            subprocess.Popen(exe, shell=True)
            logger.info(f"Launched: {exe}")
            return {"success": True}
        except Exception as e:
            logger.error(f"Failed to launch {exe}: {e}")
            return {"success": False, "error": str(e)}

    def close_app(self, app_name: str) -> dict:
        key = app_name.lower().strip()
        exe = APP_MAP.get(key, key).replace(".exe", "").lower()
        killed = False
        for proc in psutil.process_iter(["name", "pid"]):
            if exe in proc.info["name"].lower():
                proc.kill()
                killed = True
                logger.info(f"Killed process: {proc.info['name']}")
        return {"success": killed}